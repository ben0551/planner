# Internal URL the Next.js server uses to reach PocketBase
# Docker: use the service name — http://pocketbase:8090 (already set in docker-compose)
# Local dev: http://localhost:8090
PB_INTERNAL_URL=http://localhost:8090

# PocketBase superuser credentials
# These are the credentials you use to log into the PocketBase admin panel at /_/
# Required for: Sync Database, PIN reset, and kid login lookup
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=your-admin-password

# Email address of the Planner app user who should have admin access
# This is your regular household login email (not the PocketBase superuser email)
# Controls: signup toggle, approval queue, push notification broadcasts
ADMIN_EMAIL=you@example.com

# Your public domain (used by Traefik routing rule)
DOMAIN=planner.yourdomain.com

# Public URL of this app — used as the Google OAuth2 redirect URI
# Must match exactly what you register in Google Cloud Console
APP_URL=https://planner.yourdomain.com

# Google Calendar OAuth2 credentials
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI must be: ${APP_URL}/api/google-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web Push (PWA notifications)
# Generate with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
# VAPID_SUBJECT must be a mailto: or https: URL
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # same value as VAPID_PUBLIC_KEY

# Household mode: "single" (default) or "multi"
# single — one household per install; root URL goes straight to the dashboard
# multi  — public landing page; each household gets a /slug URL for kid login
HOUSEHOLD_MODE=single
