# Internal URL the Next.js server uses to reach PocketBase
# Docker: use the service name — http://pocketbase:8090 (already set in docker-compose)
# Local dev: http://localhost:8090
PB_INTERNAL_URL=http://localhost:8090

# PocketBase superuser credentials
# These are the credentials you use to log into the PocketBase admin panel at /_/
# Required for: Sync Database, PIN reset, and kid login lookup
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=your-admin-password

# Public URL of this app — used as the Google OAuth2 redirect URI
# Must match exactly what you register in Google Cloud Console
APP_URL=http://localhost:3000

# Google Calendar OAuth2 credentials
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI must be: ${APP_URL}/api/google-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
