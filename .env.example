# PocketBase URL — update to your server's address for production
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# PocketBase superuser credentials
# These are the credentials you use to log into the PocketBase admin panel at /api/_/
# Required for: Sync Database, PIN reset, and kid login lookup
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=your-admin-password
